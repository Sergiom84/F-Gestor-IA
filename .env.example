# Supabase project
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Direct Postgres connection for the background worker.
# Local Supabase default once Docker is running:
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Document worker
DOCUMENT_WORKER_QUEUE_NAME=document_processing
DOCUMENT_WORKER_VISIBILITY_TIMEOUT_SECONDS=300
DOCUMENT_WORKER_BATCH_SIZE=1
DOCUMENT_WORKER_POLL_SECONDS=5
DOCUMENT_WORKER_POLL_INTERVAL_MS=250
DOCUMENT_WORKER_IDLE_SLEEP_MS=1000
DOCUMENT_WORKER_MAX_CHUNK_CHARS=5000
DOCUMENT_WORKER_RETRY_BASE_SECONDS=30

# OpenAI invoice extraction
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_BASE_URL=https://api.openai.com
OPENAI_TIMEOUT_MS=60000

# Optional cost tracking. Use cents per 1M tokens for the selected model.
# Leave empty to skip ai_cost_events until pricing is configured.
OPENAI_INPUT_COST_PER_MILLION_TOKENS_CENTS=
OPENAI_OUTPUT_COST_PER_MILLION_TOKENS_CENTS=
